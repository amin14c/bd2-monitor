 
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#060d1a"
    android:fillViewport="true">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BD2 Monitor"
            android:textColor="#00b4d8"
            android:textSize="22sp"
            android:textStyle="bold"/>
        <TextView
            android:id="@+id/txtDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#5b8db8"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>
        <TextView
            android:id="@+id/txtSteps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="جارٍ تحميل الخطوات..."
            android:textColor="#5b8db8"
            android:textSize="13sp"
            android:layout_marginBottom="20dp"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginBottom="16dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="المزاج (0-10)"
                android:textColor="#5b8db8"
                android:textSize="12sp"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">
                <SeekBar
                    android:id="@+id/sliderMood"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="10"
                    android:progress="5"/>
                <TextView
                    android:id="@+id/txtMoodVal"
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:text="5"
                    android:textColor="#00b4d8"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textAlignment="center"/>
            </LinearLayout>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="الطاقة (0-10)"
                android:textColor="#5b8db8"
                android:textSize="12sp"
                android:layout_marginTop="14dp"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">
                <SeekBar
                    android:id="@+id/sliderEnergy"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="10"
                    android:progress="5"/>
                <TextView
                    android:id="@+id/txtEnergyVal"
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:text="5"
                    android:textColor="#00f5a0"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textAlignment="center"/>
            </LinearLayout>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ساعات النوم (0-12)"
                android:textColor="#5b8db8"
                android:textSize="12sp"
                android:layout_marginTop="14dp"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">
                <SeekBar
                    android:id="@+id/sliderSleep"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="24"
                    android:progress="14"/>
                <TextView
                    android:id="@+id/txtSleepVal"
                    android:layout_width="40dp"
                    android:layout_height="wrap_content"
                    android:text="7.0"
                    android:textColor="#ffd60a"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textAlignment="center"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginBottom="16dp">
            <CheckBox
                android:id="@+id/checkMedication"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="تناولت الدواء اليوم"
                android:textColor="#e2f0ff"
                android:textSize="15sp"
                android:buttonTint="#00f5a0"/>
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginBottom="20dp">
            <EditText
                android:id="@+id/editNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="ملاحظة اليوم..."
                android:textColor="#e2f0ff"
                android:textColorHint="#3a6a96"
                android:background="@drawable/bg_input"
                android:padding="12dp"
                android:inputType="textMultiLine"
                android:minLines="3"
                android:textSize="14sp"/>
        </LinearLayout>
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="حفظ بيانات اليوم"
            android:backgroundTint="#0077b6"
            android:textColor="#ffffff"
            android:textSize="16sp"/>
    </LinearLayout>
</ScrollView>
