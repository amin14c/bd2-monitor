<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#060d1a">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📅 سجل الأيام / Historique"
        android:textColor="#00b4d8"
        android:textSize="18sp"
        android:textStyle="bold"
        android:padding="20dp"/>

    <TextView
        android:id="@+id/txtEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="لا توجد سجلات بعد / Aucun enregistrement"
        android:textColor="#5b8db8"
        android:textSize="14sp"
        android:gravity="center"
        android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerHistory"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"/>

    <Button
        android:id="@+id/btnBack"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="رجوع / Retour"
        android:backgroundTint="#1a3a5c"
        android:textColor="#ffffff"
        android:layout_margin="16dp"/>

</LinearLayout>
